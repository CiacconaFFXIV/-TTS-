<Window x:Class="渔人的直感.Settings" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:Properties="clr-namespace:渔人的直感.Properties" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:渔人的直感" xmlns:models="clr-namespace:渔人的直感.Models" mc:Ignorable="d" Title="设置" ResizeMode="NoResize" WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" Loaded="Settings_Loaded">
    <GroupBox Header="参数设置" Margin="7">
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock TextWrapping="Wrap" Text="宽度" Margin="4" />
                <TextBox  Text="{Binding Path=Width,Source={x:Static Properties:Settings.Default}}" Width="63" Margin="4" />
                <TextBlock TextWrapping="Wrap" Text="高度" Margin="4" />
                <TextBox Text="{Binding Path=Height,Source={x:Static Properties:Settings.Default}}" Width="63" Margin="4" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock TextWrapping="Wrap" Text="抛竿颜色" VerticalAlignment="Center" Width="110" />
                <Button Name="TimerColorButton" Width="80" Height="24" Margin="4,0,0,0" Click="TimerColorButton_Click" ToolTip="点击打开色盘" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock TextWrapping="Wrap" Text="轻杆颜色" VerticalAlignment="Center" Width="110" />
                <Button Name="LTugColorButton" Width="80" Height="24" Margin="4,0,0,0" Click="LTugColorButton_Click" ToolTip="点击打开色盘" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock TextWrapping="Wrap" Text="中杆颜色" VerticalAlignment="Center" Width="110" />
                <Button Name="MTugColorButton" Width="80" Height="24" Margin="4,0,0,0" Click="MTugColorButton_Click" ToolTip="点击打开色盘" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock TextWrapping="Wrap" Text="鱼王杆颜色" VerticalAlignment="Center" Width="110" />
                <Button Name="HTugColorButton" Width="80" Height="24" Margin="4,0,0,0" Click="HTugColorButton_Click" ToolTip="点击打开色盘" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock TextWrapping="Wrap" Text="鱼眼/天气颜色" VerticalAlignment="Center" Width="110" />
                <Button Name="StatusColorButton" Width="80" Height="24" Margin="4,0,0,0" Click="StatusColorButton_Click" ToolTip="点击打开色盘" />
            </StackPanel>
            <CheckBox Content="监视空岛特殊天气" Margin="4" IsChecked="{Binding Path=CheckDiademWeather,Source={x:Static Properties:Settings.Default}}" ToolTip="当空岛特殊天气触发时启动10分钟倒计时。此选项不影响幻海流计时。"/>
            <CheckBox Content="鼠标穿透(将同时禁用菜单与拖动)" Margin="4" IsChecked="{Binding Path=ClickThrough,Source={x:Static Properties:Settings.Default}}" ToolTip="阻止直感窗体因获得焦点而干扰游戏。此选项开启后直感的计时条将无法拖动或右键展开菜单，需要修改时需要使用托盘图标右键呼出设置菜单。" />
            <CheckBox Content="未活动时隐藏窗体(仅抛竿时可见)" Margin="4" IsChecked="{Binding Path=HideWhenNotActived,Source={x:Static Properties:Settings.Default}}" ToolTip="当未处于抛竿或特殊天气时将会隐藏直感窗体。直感窗体隐藏中的场合，只能通过结束游戏或右键托盘图标退出直感进程。" />
            <Separator Margin="4,8,4,4" />
            <TextBlock Margin="4,0,4,2" FontWeight="Bold" Text="鱼识显示" />
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="字体" VerticalAlignment="Center" Width="110" />
                <TextBox Width="180" Text="{Binding Path=FishIntuitionFontFamily,Source={x:Static Properties:Settings.Default}}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="字号" VerticalAlignment="Center" Width="110" />
                <TextBox Width="80" Text="{Binding Path=FishIntuitionFontSize,Source={x:Static Properties:Settings.Default}}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="文字颜色" VerticalAlignment="Center" Width="110" />
                <Button Name="FishIntuitionColorButton" Width="80" Height="24" Margin="4,0,0,0" Click="FishIntuitionColorButton_Click" ToolTip="点击打开色盘" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="阴影颜色" VerticalAlignment="Center" Width="110" />
                <Button Name="FishIntuitionShadowColorButton" Width="80" Height="24" Margin="4,0,0,0" Click="FishIntuitionShadowColorButton_Click" ToolTip="点击打开色盘" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="与进度条间距" VerticalAlignment="Center" Width="110" />
                <TextBox Width="80" Text="{Binding Path=FishIntuitionSpacing,Source={x:Static Properties:Settings.Default}}" />
            </StackPanel>
            <Separator Margin="4,8,4,4" />
            <CheckBox Content="启用 TTS 咬钩播报" Margin="4" IsChecked="{Binding Path=TtsEnabled,Source={x:Static Properties:Settings.Default}}" ToolTip="咬钩时使用 Windows 语音播报杆型，可与杆型音频调整播放时机。" />
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="TTS 相对音频(ms)" VerticalAlignment="Center" Width="110" />
                <Slider Name="TtsTimingSlider" Width="180" VerticalAlignment="Center"
                        IsSnapToTickEnabled="False"
                        Value="{Binding Path=TtsTimingOffsetMs,Source={x:Static Properties:Settings.Default}}" />
                <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" MinWidth="48"
                           Text="{Binding ElementName=TtsTimingSlider, Path=Value, StringFormat={}{0:F0}}" />
            </StackPanel>
            <TextBlock Margin="4,0,4,4" Foreground="Gray" TextWrapping="Wrap"
                       Text="0 为与音频同时播放；负值 TTS 更早，正值 TTS 更晚。范围：-TTS时长 ~ 音频时长。" />
            <StackPanel Orientation="Horizontal">
                <Button Content="应用" Width="98" Margin="2" Click="Apply_Button_Click" />
                <Button Content="重置" Width="98" Margin="2" Click="Reset_Button_Click" />
            </StackPanel>
        </StackPanel>
    </GroupBox>
</Window>
